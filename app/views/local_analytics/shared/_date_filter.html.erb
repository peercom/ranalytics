<form method="get" class="la-date-form">
  <input type="hidden" name="property_id" value="<%= current_property&.id %>">
  <% if defined?(extra_params) && extra_params.present? %>
    <% extra_params.each do |k, v| %>
      <input type="hidden" name="<%= k %>" value="<%= v %>">
    <% end %>
  <% end %>
  <input type="date" name="from" value="<%= date_range.first %>">
  <span>&mdash;</span>
  <input type="date" name="to" value="<%= date_range.last %>">
  <select name="compare" style="padding:0.3rem; border:1px solid var(--border); border-radius:4px; font-size:12px; color:var(--text-muted);">
    <option value="">No comparison</option>
    <option value="previous" <%= "selected" if params[:compare] == "previous" %>>Previous period</option>
    <option value="year" <%= "selected" if params[:compare] == "year" %>>Same period last year</option>
  </select>
  <button type="submit">Apply</button>
</form>
