<div class="la-header">
  <h1>Campaigns</h1>
  <div style="display:flex; gap:0.5rem; align-items:center;">
    <%= render "local_analytics/shared/date_filter" %>
    <%= link_to "CSV", export_campaigns_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, format: :csv), class: "la-export" %>
  </div>
</div>

<div class="la-panel">
  <table>
    <thead>
      <tr>
        <th>Campaign</th>
        <th>Source</th>
        <th>Medium</th>
        <th class="num">Visits</th>
        <th class="num">Visitors</th>
        <th class="num">Bounces</th>
      </tr>
    </thead>
    <tbody>
      <% @report.rows.each do |row| %>
        <tr>
          <td><%= row.utm_campaign %></td>
          <td><%= row.utm_source %></td>
          <td><%= row.utm_medium %></td>
          <td class="num"><%= number_with_delimiter(row.visits) %></td>
          <td class="num"><%= number_with_delimiter(row.visitors) %></td>
          <td class="num"><%= number_with_delimiter(row.bounces) %></td>
        </tr>
      <% end %>
      <% if @report.rows.empty? %>
        <tr><td colspan="6" class="la-empty">No campaign data for this period</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
