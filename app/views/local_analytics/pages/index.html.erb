<div class="la-header">
  <h1>Pages</h1>
  <div style="display:flex; gap:0.5rem; align-items:center;">
    <%= render "local_analytics/shared/date_filter", extra_params: { type: params[:type] } %>
    <%= link_to "CSV", export_pages_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, type: params[:type], format: :csv), class: "la-export" %>
  </div>
</div>

<div class="la-tabs">
  <%= link_to "All Pages", pages_path(property_id: current_property&.id, from: date_range.first, to: date_range.last), class: (params[:type].blank? || params[:type] == "all") ? "active" : "" %>
  <%= link_to "Entry Pages", pages_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, type: "entry"), class: params[:type] == "entry" ? "active" : "" %>
  <%= link_to "Exit Pages", pages_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, type: "exit"), class: params[:type] == "exit" ? "active" : "" %>
</div>

<% if comparing? && @report.comparison_by_path.any? %>
  <div style="font-size:12px; color:var(--text-muted); margin-bottom:0.75rem;">
    Comparing vs <strong><%= comparison_range.first %> &ndash; <%= comparison_range.last %></strong>
  </div>
<% end %>

<div class="la-panel">
  <table>
    <thead>
      <tr>
        <th>Path</th>
        <% if params[:type] == "entry" %>
          <th class="num">Entries</th>
          <th class="num">Bounces</th>
          <th class="num">Bounce Rate</th>
        <% elsif params[:type] == "exit" %>
          <th class="num">Exits</th>
          <th class="num">Pageviews</th>
          <th class="num">Exit Rate</th>
        <% else %>
          <th class="num">Pageviews</th>
          <% if comparing? %><th class="num" style="color:var(--text-muted)">Prev</th><th class="num">Change</th><% end %>
          <th class="num">Visitors</th>
          <th class="num">Entries</th>
          <th class="num">Exits</th>
          <th class="num">Bounce Rate</th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @report.rows.each do |row| %>
        <tr>
          <td><%= truncate(row.path, length: 80) %></td>
          <% if params[:type] == "entry" %>
            <td class="num"><%= number_with_delimiter(row.entries) %></td>
            <td class="num"><%= number_with_delimiter(row.bounces) %></td>
            <td class="num"><%= row.bounce_rate %>%</td>
          <% elsif params[:type] == "exit" %>
            <td class="num"><%= number_with_delimiter(row.exits) %></td>
            <td class="num"><%= number_with_delimiter(row.pageviews) %></td>
            <td class="num"><%= row.exit_rate %>%</td>
          <% else %>
            <% current_pv = row.pageviews.to_i %>
            <td class="num"><%= number_with_delimiter(current_pv) %></td>
            <% if comparing? %>
              <% prev_pv = @report.comparison_by_path[row.path] || 0 %>
              <td class="num" style="color:var(--text-muted)"><%= number_with_delimiter(prev_pv) %></td>
              <td class="num">
                <% delta = prev_pv > 0 ? ((current_pv.to_f - prev_pv) / prev_pv * 100).round(1) : nil %>
                <%= render "local_analytics/shared/comparison_badge", delta: delta, invert: false %>
              </td>
            <% end %>
            <td class="num"><%= number_with_delimiter(row.visitors) %></td>
            <td class="num"><%= row.try(:entries) %></td>
            <td class="num"><%= row.try(:exits) %></td>
            <td class="num"><%= row.try(:bounce_rate) %>%</td>
          <% end %>
        </tr>
      <% end %>
      <% if @report.rows.empty? %>
        <tr><td colspan="<%= comparing? ? 8 : 6 %>" class="la-empty">No data for this period</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
