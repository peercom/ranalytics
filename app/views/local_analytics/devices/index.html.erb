<div class="la-header">
  <h1>Devices</h1>
  <div style="display:flex; gap:0.5rem; align-items:center;">
    <%= render "local_analytics/shared/date_filter", extra_params: { dimension: params[:dimension] } %>
    <%= link_to "CSV", export_devices_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, dimension: params[:dimension], format: :csv), class: "la-export" %>
  </div>
</div>

<div class="la-tabs">
  <%= link_to "Device Type", devices_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, dimension: "device_type"), class: (params[:dimension].blank? || params[:dimension] == "device_type") ? "active" : "" %>
  <%= link_to "Browsers", devices_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, dimension: "browser"), class: params[:dimension] == "browser" ? "active" : "" %>
  <%= link_to "Operating Systems", devices_path(property_id: current_property&.id, from: date_range.first, to: date_range.last, dimension: "os"), class: params[:dimension] == "os" ? "active" : "" %>
</div>

<div class="la-panel">
  <table>
    <thead>
      <tr>
        <th><%= (params[:dimension] || "device_type").humanize %></th>
        <th class="num">Visits</th>
        <th class="num">Visitors</th>
      </tr>
    </thead>
    <tbody>
      <% @report.rows.each do |row| %>
        <tr>
          <td><%= row.send(params[:dimension] || "device_type") %></td>
          <td class="num"><%= number_with_delimiter(row.visits) %></td>
          <td class="num"><%= number_with_delimiter(row.visitors) %></td>
        </tr>
      <% end %>
      <% if @report.rows.empty? %>
        <tr><td colspan="3" class="la-empty">No device data for this period</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
