<div class="la-header">
  <h1><%= @goal.name %></h1>
  <%= render "local_analytics/shared/date_filter" %>
</div>

<div class="la-cards">
  <div class="la-card">
    <div class="la-card-label">Conversions</div>
    <div class="la-card-value"><%= number_with_delimiter(@report.total_conversions) %></div>
  </div>
  <div class="la-card">
    <div class="la-card-label">Conversion Rate</div>
    <div class="la-card-value"><%= @report.conversion_rate %>%</div>
  </div>
  <div class="la-card">
    <div class="la-card-label">Revenue</div>
    <div class="la-card-value"><%= number_to_currency(@report.total_revenue) %></div>
  </div>
</div>

<% daily = @report.daily_conversions.sort %>
<% if daily.any? %>
<div class="la-panel">
  <h3>Daily Conversions</h3>
  <%= la_area_chart(
    series: { "Conversions" => daily.map(&:last) },
    labels: daily.map { |d, _| d.to_date.strftime("%-m/%-d") },
    height: 200
  ) %>

  <details style="margin-top: 0.75rem;">
    <summary style="cursor:pointer; font-size:12px; color:var(--text-muted);">Show table</summary>
    <table style="margin-top:0.5rem;">
      <thead><tr><th>Date</th><th class="num">Conversions</th></tr></thead>
      <tbody>
        <% daily.each do |date, count| %>
          <tr><td><%= date %></td><td class="num"><%= count %></td></tr>
        <% end %>
      </tbody>
    </table>
  </details>
</div>
<% end %>
